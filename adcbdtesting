local Http = game:GetService("HttpService")

local function loadConfig()
    if not isfile(CFG_FILE) then return {} end
    local ok, data = pcall(function() return Http:JSONDecode(readfile(CFG_FILE)) end)
    return (ok and type(data) == "table") and data or {}
end

local function saveConfig(tbl)
    pcall(function() writefile(CFG_FILE, Http:JSONEncode(tbl)) end)
end

local Config = loadConfig()

local function cfgGet(key, default)
    local v = Config[key]
    if v == nil then return default end
    return v
end

local function cfgSet(key, value)
    Config[key] = value
    saveConfig(Config)
end

