-- sync valid targets every 0.5s so the actor payload can read them
task.spawn(function()
    while true do
        local tbl = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp then
                local role = getPlayerRole(p)
                for _, targetRole in ipairs(AimbotConfig.targets) do
                    if role == targetRole then tbl[p.Name] = true; break end
                end
            end
        end
        local s = "{"
        for name in pairs(tbl) do s = s .. '["' .. name .. '"]=true,' end
        s = s .. "}"
        getgenv().validTargets  = tbl
        getgenv().aimbotEnabled = AimbotConfig.enabled
        getgenv().hitChance     = AimbotConfig.hitChance
        getgenv().wallcheck     = AimbotConfig.wallCheck
        getgenv().radius        = AimbotConfig.fov
        local pts = "{"
        for i, p in ipairs(AimbotConfig.targetParts) do
            pts = pts .. '"' .. p .. '"' .. (i == #AimbotConfig.targetParts and "" or ",")
        end
        pts = pts .. "}"
        getgenv().targetParts = AimbotConfig.targetParts
        task.wait(0.5)
    end
end)

