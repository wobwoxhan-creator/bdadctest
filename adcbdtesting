local function applyBoostToHum(hum)
    if speedMultiplier == 1.00 then return end
    isApplyingBoost = true
    hum.WalkSpeed = baseWalkSpeed * speedMultiplier
    isApplyingBoost = false
end

local function hookHumanoid(hum)
    if speedHumConnection then speedHumConnection:Disconnect() speedHumConnection = nil end
    baseWalkSpeed = hum.WalkSpeed
    speedHumConnection = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if isApplyingBoost then return end
        baseWalkSpeed = hum.WalkSpeed
        applyBoostToHum(hum)
    end)
    applyBoostToHum(hum)
end

