-- auto aim
local AutoAimCfg = {
    enabled    = false,
    fov        = 300,
    fovVisible = true,
    smoothness = 0.3,
    part       = "Head",
}

local autoAimFovCircle         = Drawing.new("Circle")
autoAimFovCircle.Filled        = false
autoAimFovCircle.NumSides      = 60
autoAimFovCircle.Thickness     = 1.5
autoAimFovCircle.Color         = Color3.fromRGB(255, 100, 100)

RunService.RenderStepped:Connect(function()
    local vp = Camera.ViewportSize
    autoAimFovCircle.Radius   = AutoAimCfg.fov
    autoAimFovCircle.Position = Vector2.new(vp.X / 2, vp.Y / 2)
    autoAimFovCircle.Visible  = AutoAimCfg.fovVisible and AutoAimCfg.enabled

    if not AutoAimCfg.enabled then return end

    local UIS    = game:GetService("UserInputService")
    local center = Vector2.new(vp.X / 2, vp.Y / 2)
    local bestPart, bestDist = nil, AutoAimCfg.fov

    local npc = Workspace:FindFirstChild("NPCSFolder")
    if not npc then return end
    local targets = AutoAimCfg.targets or {"Killer"}

    for _, char in next, npc:GetChildren() do
        if char == lp.Character then continue end

        -- role check via validTargets
        if not validTargets[char.Name] then continue end

        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local pt = char:FindFirstChild(AutoAimCfg.part) or char:FindFirstChild("HumanoidRootPart")
        if not pt then continue end

        local vPoint, onScreen = Camera:WorldToViewportPoint(pt.Position)
        if not onScreen then continue end

        local screenDist = (Vector2.new(vPoint.X, vPoint.Y) - center).Magnitude
        if screenDist < bestDist then
            bestDist = screenDist
            bestPart = pt
        end
    end

    if bestPart then
        local targetCF = CFrame.new(Camera.CFrame.Position, bestPart.Position)
        Camera.CFrame  = Camera.CFrame:Lerp(targetCF, AutoAimCfg.smoothness)
    end
end)

