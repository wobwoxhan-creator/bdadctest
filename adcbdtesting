        getgenv().radius        = AimbotConfig.fov
        local pts = "{"
        for i, p in ipairs(AimbotConfig.targetParts) do
            pts = pts .. '"' .. p .. '"' .. (i == #AimbotConfig.targetParts and "" or ",")
        end
        pts = pts .. "}"
        getgenv().targetParts = AimbotConfig.targetParts
        task.wait(0.5)
    end
end)

-- payload injected into each gun's Actor
-- hooks RS.gun_res.lib.replicator bullet function
local PAYLOAD = [[
local cloneref      = cloneref or function(i) return i end
local clonefunction = clonefunction or function(f) return f end
local newcclosure   = newcclosure or clonefunction

local RS        = cloneref(game:GetService("ReplicatedStorage"))
local Players   = cloneref(game:GetService("Players"))
local Workspace = game:GetService("Workspace")
local lp        = Players.LocalPlayer
local Camera    = Workspace.CurrentCamera

if getgenv().aimbotEnabled == nil then getgenv().aimbotEnabled = false end
if getgenv().hitChance     == nil then getgenv().hitChance     = 100   end
if getgenv().wallCheck     == nil then getgenv().wallCheck     = false end
if getgenv().radius        == nil then getgenv().radius        = 300   end
if getgenv().targetParts   == nil then getgenv().targetParts   = {"Head","Torso","HumanoidRootPart"} end
if getgenv().validTargets  == nil then getgenv().validTargets  = {}    end

local rayParams = RaycastParams.new()
rayParams.FilterType  = Enum.RaycastFilterType.Exclude
rayParams.IgnoreWater = true

local function getTargetPart(origin)
    local vp     = Camera.ViewportSize
    local center = Vector2.new(vp.X / 2, vp.Y / 2)
    local parts  = getgenv().targetParts
    local valid  = getgenv().validTargets
    local bestPos, bestW = nil, -math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and valid[player.Name] then
            local char = player.Character
            if char then
                local hum  = char:FindFirstChildOfClass("Humanoid")
                local root = char:FindFirstChild("HumanoidRootPart")
                if hum and hum.Health > 0 and root then
                    local targetPos
                    for _, partName in ipairs(parts) do
                        local p = char:FindFirstChild(partName)
                        if p and p:IsA("BasePart") then
                            targetPos = p.Position
                            break
                        end
                    end
                    if targetPos then
                        local vPoint = Camera:WorldToViewportPoint(root.Position)
                        if vPoint.Z >= 0 then
                            local wallBlocked = false
                            if getgenv().wallCheck then
                                rayParams.FilterDescendantsInstances = { char, lp.Character }
                                local hit = Workspace:Raycast(Camera.CFrame.Position, root.Position - Camera.CFrame.Position, rayParams)
                                if hit then wallBlocked = true end
                            end
                            if not wallBlocked then
                                local sd = (Vector2.new(vPoint.X, vPoint.Y) - center).Magnitude
                                if sd <= getgenv().radius then
                                    local w = 1000 - sd
                                    if w > bestW then
                                        bestW   = w
                                        bestPos = targetPos
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return bestPos
end

local s, rep = pcall(require, RS.gun_res.lib.replicator)
if not s or not rep then return end

local bulletFn = rawget(rep, "bullet")
if not bulletFn then return end

local old; old = clonefunction(hookfunction(bulletFn, newcclosure(function(_, __, ___, ____, origin, endPoses, ...)
    if getgenv().aimbotEnabled and math.random(1, 100) <= getgenv().hitChance then
        local targetPos = getTargetPart(origin)
        if targetPos then
            local dir = (targetPos - origin).Unit
            return old(_, __, ___, ____, origin, table.create(#endPoses, dir), ...)
        end
    end
    return old(_, __, ___, ____, origin, endPoses, ...)
end)))
]]

-- inject payload into gun actor, retry until it sticks
local injectedActors = {}

local function injectActor(gun)
    if not run_on_actor then return end
    local actor = gun:FindFirstChild("Actor")
    if not actor then return end
    if injectedActors[actor] then return end

    task.spawn(function()
        local retries = 0
        while retries < 100 do
            if not actor.Parent then return end
            local ok = pcall(run_on_actor, actor, PAYLOAD)
            if ok then injectedActors[actor] = true; return end
            retries += 1
            task.wait(0.05)
        end
    end)
end

local function setupChar(char)
    table.clear(injectedActors)
    local function checkTool(child)
        if child.ClassName == "Tool" then
            local actor = child:FindFirstChild("Actor")
            if actor and actor:FindFirstChild("weap_cl") then
                injectActor(child)
            end
