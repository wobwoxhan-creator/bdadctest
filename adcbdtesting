local function hasAnyTeamTag()
    local lpChar = lp.Character
    if not lpChar then return false end
    return lpChar:FindFirstChild("TEAM1") ~= nil or lpChar:FindFirstChild("TEAM2") ~= nil
end

local function isEnemyTeam(npcChar)
    local lpChar = lp.Character
    if not lpChar or not npcChar then return false end
    local lpTeam1 = lpChar:FindFirstChild("TEAM1") ~= nil
    local lpTeam2 = lpChar:FindFirstChild("TEAM2") ~= nil
    if not lpTeam1 and not lpTeam2 then return false end
    if lpTeam1 and npcChar:FindFirstChild("TEAM1") then return false end
    if lpTeam2 and npcChar:FindFirstChild("TEAM2") then return false end
    if lpTeam1 and npcChar:FindFirstChild("TEAM2") then return true end
    if lpTeam2 and npcChar:FindFirstChild("TEAM1") then return true end
    return false
end

local function isSameTeam(npcChar)
