local function watchPlayerForFirstItem(player)
    if firstItemConnections[player] then
        for _, conn in ipairs(firstItemConnections[player]) do
            if conn and conn.Connected then conn:Disconnect() end
        end
    end
    firstItemConnections[player] = {}
    playerFirstItems[player] = nil

    local function checkTool(tool)
        if not tool:IsA("Tool") then return end
        if blacklistedItems[tool.Name] then return end
        if not playerFirstItems[player] then
            playerFirstItems[player] = tool.Name
        end
    end

    local function hookChar(char)
        if not char then return end
        for _, child in ipairs(char:GetChildren()) do checkTool(child) end
        if playerFirstItems[player] then return end
        local conn = char.ChildAdded:Connect(function(child) checkTool(child) end)
        table.insert(firstItemConnections[player], conn)
    end

    local function hookBackpack(backpack)
        if not backpack then return end
        for _, child in ipairs(backpack:GetChildren()) do checkTool(child) end
        if playerFirstItems[player] then return end
        local conn = backpack.ChildAdded:Connect(function(child) checkTool(child) end)
        table.insert(firstItemConnections[player], conn)
    end

    local function hookNPC()
        if not NPCSFolder then return end
        local npcModel = NPCSFolder:FindFirstChild(player.Name)
        if npcModel then
            for _, child in ipairs(npcModel:GetChildren()) do checkTool(child) end
            if playerFirstItems[player] then return end
            local conn = npcModel.ChildAdded:Connect(function(child) checkTool(child) end)
            table.insert(firstItemConnections[player], conn)
        end
    end

    hookChar(player.Character)
    hookBackpack(player:FindFirstChildOfClass("Backpack"))
    hookNPC()

    local charConn = player.CharacterAdded:Connect(function(char)
        playerFirstItems[player] = nil
        hookChar(char)
        hookBackpack(player:FindFirstChildOfClass("Backpack"))
        hookNPC()
    end)
    table.insert(firstItemConnections[player], charConn)
end

