local function getWeaponRole(weaponName)
    if killerWeapons[weaponName]    then return "Killer"    end
    if vigilanteWeapons[weaponName] then return "Vigilante" end
    return nil
end

local function getPlayerWeapons(player)
    -- returns a list of all weapon names (equipped + backpack)
    local found = {}
    local char = player.Character
    if char then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then found[#found+1] = item.Name end
        end
    end
    local bp = player:FindFirstChildOfClass("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            if item:IsA("Tool") then found[#found+1] = item.Name end
        end
    end
    return found
end

local function getPlayerRole(player)
    local weapons = getPlayerWeapons(player)
    if #weapons == 0 then return "Innocent", nil end
    -- killer takes priority over vigilante
    for _, name in ipairs(weapons) do
        if killerWeapons[name] then return "Killer", name end
    end
    for _, name in ipairs(weapons) do
        if vigilanteWeapons[name] then return "Vigilante", name end
    end
    -- has a weapon but it's not in either list (team war etc) = innocent
    return "Innocent", weapons[1]
end

local function getRoleColor(role)
    if role == "Killer"    then return espColors.killer    end
    if role == "Vigilante" then return espColors.vigilante end
    return espColors.innocent
end

-- ESP
local espEnabled = false
local espObjects = {}

local function cleanupESP(player)
    local obj = espObjects[player]
    if not obj then return end
    if obj.conn      then obj.conn:Disconnect()   end
    if obj.highlight then obj.highlight:Destroy() end
    if obj.billboard then obj.billboard:Destroy() end
    espObjects[player] = nil
end

local function getPlayerFromName(name)
    return Players:FindFirstChild(name)
end

local function setupESP(player, charOverride)
    cleanupESP(player)
    if not espEnabled or player == lp then return end

    local npc  = Workspace:FindFirstChild("NPCSFolder")
    local char = charOverride
        or (npc and npc:FindFirstChild(player.Name))
        or player.Character
    if not char then return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local hl = Instance.new("Highlight")
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillTransparency    = 0.6
    hl.OutlineTransparency = 0.2
    hl.Adornee             = char
    hl.Parent              = CoreGui

    local bb = Instance.new("BillboardGui")
    bb.Size        = UDim2.fromOffset(160, 20)
    bb.StudsOffset = Vector3.new(0, 2.8, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = 1000
    bb.Adornee     = hrp
    bb.Parent      = CoreGui

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size                   = UDim2.fromScale(1, 1)
    lbl.TextScaled             = false
    lbl.TextSize               = 11
    lbl.Font                   = Enum.Font.Gotham
    lbl.TextStrokeTransparency = 0.3
    lbl.TextColor3             = Color3.new(1, 1, 1)
    lbl.Parent                 = bb

    local conn = RunService.RenderStepped:Connect(function()
        if not char.Parent or hum.Health <= 0 then
            hl.Enabled = false
            bb.Enabled = false
            return
        end

        local role, _ = getPlayerRole(player)
        local color   = getRoleColor(role)
        local dist    = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)

        hl.FillColor    = color
        hl.OutlineColor = color
        hl.Enabled      = true
        bb.Enabled      = true

        lbl.TextColor3 = color
        lbl.Text       = player.Name .. "  " .. dist .. "m"
    end)

    espObjects[player] = { highlight = hl, billboard = bb, conn = conn }
end

local function enableAllESP()
    local npc = Workspace:FindFirstChild("NPCSFolder")
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then
            local char = (npc and npc:FindFirstChild(p.Name)) or p.Character
            if char then setupESP(p, char) end
        end
    end
end

local function disableAllESP()
    for p in pairs(espObjects) do cleanupESP(p) end
end

task.spawn(function()
    local npc = Workspace:FindFirstChild("NPCSFolder") or Workspace:WaitForChild("NPCSFolder", 30)
    if not npc then return end

    for _, char in ipairs(npc:GetChildren()) do
        local p = getPlayerFromName(char.Name)
        if p and p ~= lp and espEnabled then setupESP(p, char) end
    end

    npc.ChildAdded:Connect(function(char)
        task.wait()
        if not espEnabled then return end
        local p = getPlayerFromName(char.Name)
        if p and p ~= lp then setupESP(p, char) end
    end)

    npc.ChildRemoved:Connect(function(char)
        local p = getPlayerFromName(char.Name)
        if p then cleanupESP(p) end
    end)
end)

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= lp then
        p.AncestryChanged:Connect(function(_, parent)
            if not parent then cleanupESP(p) end
        end)
    end
end

Players.PlayerAdded:Connect(function(p)
    if p == lp then return end
    p.AncestryChanged:Connect(function(_, parent)
        if not parent then cleanupESP(p) end
    end)
end)

Players.PlayerRemoving:Connect(function(p) cleanupESP(p) end)

