local speedCfg = { enabled = false, multiplier = 1.0 }
local _lastSpeed, _speedConn = nil, nil

local function getHum()
    local char = lp.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function applySpeed(hum)
    if not hum then return end
    local cur  = hum.WalkSpeed
    local base = (_lastSpeed and math.abs(cur - _lastSpeed) < 0.01)
        and (_lastSpeed / speedCfg.multiplier)
        or cur
    _lastSpeed = base * speedCfg.multiplier
    hum.WalkSpeed = _lastSpeed
end

local function hookSpeedChar(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    _lastSpeed = nil
    applySpeed(hum)
    if _speedConn then _speedConn:Disconnect() end
    _speedConn = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if not speedCfg.enabled then return end
        if _lastSpeed and math.abs(hum.WalkSpeed - _lastSpeed) < 0.01 then return end
        applySpeed(hum)
    end)
end

local function enableSpeed()
    if lp.Character then task.spawn(hookSpeedChar, lp.Character) end
end

local function disableSpeed()
    if _speedConn then _speedConn:Disconnect(); _speedConn = nil end
    local hum = getHum()
    if hum and _lastSpeed then hum.WalkSpeed = _lastSpeed / speedCfg.multiplier end
    _lastSpeed = nil
end

lp.CharacterAdded:Connect(function(char)
    if speedCfg.enabled then task.wait(0.3); hookSpeedChar(char) end
end)

MiscTab:CreateToggle({
    Name         = "Speed Boost",
    CurrentValue = cfgGet("SpeedEnabled", false),
    Flag         = "SpeedEnabled",
    Callback     = function(val)
        cfgSet("SpeedEnabled", val)
        if _cfgApplying then return end
        speedCfg.enabled = val
        if val then enableSpeed() else disableSpeed() end
    end,
})

MiscTab:CreateSlider({
    Name         = "Speed Multiplier",
    Range        = {100, 120},
    Increment    = 1,
    Suffix       = "%",
    CurrentValue = cfgGet("SpeedMult", 100),
    Flag         = "SpeedMult",
    Callback     = function(val)
        cfgSet("SpeedMult", val)
        if _cfgApplying then return end
        local old = speedCfg.multiplier
        speedCfg.multiplier = val / 100
        if speedCfg.enabled then
            local hum = getHum()
            if hum and _lastSpeed then
                local base = _lastSpeed / old
                _lastSpeed = base * speedCfg.multiplier
                hum.WalkSpeed = _lastSpeed
            end
        end
    end,
})



-- item esp
local itemESPEnabled   = false
local droppedGunConns  = {}
local meleeConns       = {}
local meleeWatchConn   = nil

local DROPPED_COLOR = Color3.fromRGB(255, 220, 0)
local MELEE_COLOR   = Color3.fromRGB(255, 100, 50)

local function addHighlight(instance, color, parent)
    local existing = instance:FindFirstChild("_ADCHighlight")
    if existing then existing:Destroy() end
    local hl = Instance.new("Highlight")
    hl.Name                = "_ADCHighlight"
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillColor           = color
    hl.OutlineColor        = color
    hl.FillTransparency    = 0.4
    hl.OutlineTransparency = 0
    hl.Adornee             = instance
    hl.Parent              = parent or instance
end

local function removeHighlight(instance)
    local hl = instance:FindFirstChild("_ADCHighlight")
    if hl then hl:Destroy() end
end

-- dropped guns: Tools directly in BloodFolder
local function addDroppedGunESP(tool)
    if not tool:IsA("Tool") then return end
    addHighlight(tool, DROPPED_COLOR, tool)
    if not droppedGunConns[tool] then
        droppedGunConns[tool] = tool.AncestryChanged:Connect(function()
            if not tool.Parent then
                removeHighlight(tool)
                if droppedGunConns[tool] then
                    droppedGunConns[tool]:Disconnect()
                    droppedGunConns[tool] = nil
                end
            end
        end)
    end
end

local function clearDroppedGunESP(tool)
    removeHighlight(tool)
    if droppedGunConns[tool] then
        droppedGunConns[tool]:Disconnect()
        droppedGunConns[tool] = nil
    end
end

local function enableDroppedGunESP()
    if not BloodFolder then return end
    for _, obj in ipairs(BloodFolder:GetChildren()) do
        if obj:IsA("Tool") then addDroppedGunESP(obj) end
    end
    droppedGunConns["__added"] = BloodFolder.ChildAdded:Connect(function(obj)
        if itemESPEnabled and obj:IsA("Tool") then addDroppedGunESP(obj) end
    end)
end

local function disableDroppedGunESP()
    if BloodFolder then
        for _, obj in ipairs(BloodFolder:GetChildren()) do
            if obj:IsA("Tool") then removeHighlight(obj) end
        end
    end
    for k, conn in pairs(droppedGunConns) do
        if type(conn) ~= "string" and conn.Connected then conn:Disconnect() end
        droppedGunConns[k] = nil
    end
end

-- melee esp: BloodFolder.[mapfolder].Melees.*
local function addMeleeESP(item)
    addHighlight(item, MELEE_COLOR, item)
    if not meleeConns[item] then
        meleeConns[item] = item.AncestryChanged:Connect(function()
            if not item.Parent then
                removeHighlight(item)
                if meleeConns[item] then
                    meleeConns[item]:Disconnect()
                    meleeConns[item] = nil
                end
            end
        end)
    end
end

local function scanMeleeFolder(meleeFolder)
    for _, item in ipairs(meleeFolder:GetChildren()) do
        addMeleeESP(item)
    end
    meleeFolder.ChildAdded:Connect(function(item)
        if itemESPEnabled then addMeleeESP(item) end
    end)
end

local function scanMapFolder(mapFolder)
    local melees = mapFolder:FindFirstChild("Melees")
    if melees then scanMeleeFolder(melees) end
    mapFolder.ChildAdded:Connect(function(child)
        if itemESPEnabled and child.Name == "Melees" then
            scanMeleeFolder(child)
        end
    end)
end

local function enableMeleeESP()
    if not BloodFolder then return end
    for _, mapFolder in ipairs(BloodFolder:GetChildren()) do
        if mapFolder:IsA("Folder") then scanMapFolder(mapFolder) end
    end
    meleeWatchConn = BloodFolder.ChildAdded:Connect(function(child)
        if itemESPEnabled and child:IsA("Folder") then
            task.wait(0.1)
            scanMapFolder(child)
        end
    end)
end

local function disableMeleeESP()
    for item, conn in pairs(meleeConns) do
        removeHighlight(item)
        if conn and conn.Connected then conn:Disconnect() end
        meleeConns[item] = nil
    end
    if meleeWatchConn then meleeWatchConn:Disconnect(); meleeWatchConn = nil end
end

local function enableAllItemESP()
    enableDroppedGunESP()
    enableMeleeESP()
end

local function disableAllItemESP()
    disableDroppedGunESP()
    disableMeleeESP()
end

ItemESPTab:CreateToggle({
    Name         = "Enable Item ESP",
    CurrentValue = cfgGet("ItemESPEnabled", false),
    Flag         = "ItemESPEnabled",
    Callback     = function(val)
        cfgSet("ItemESPEnabled", val)
        if _cfgApplying then return end
        itemESPEnabled = val
