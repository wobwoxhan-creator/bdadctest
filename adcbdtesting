local function getWeaponRole(weaponName)
    if killerWeapons[weaponName]    then return "Killer"    end
    if vigilanteWeapons[weaponName] then return "Vigilante" end
    return nil
end

local function getPlayerWeapons(player)
    -- returns a list of all weapon names (equipped + backpack)
    local found = {}
    local char = player.Character
    if char then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then found[#found+1] = item.Name end
        end
    end
    local bp = player:FindFirstChildOfClass("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            if item:IsA("Tool") then found[#found+1] = item.Name end
        end
    end
    return found
end

local function getPlayerRole(player)
    local weapons = getPlayerWeapons(player)
    if #weapons == 0 then return "Innocent", nil end
    -- killer takes priority over vigilante
    for _, name in ipairs(weapons) do
        if killerWeapons[name] then return "Killer", name end
    end
    for _, name in ipairs(weapons) do
        if vigilanteWeapons[name] then return "Vigilante", name end
    end
    -- has a weapon but it's not in either list (team war etc) = innocent
    return "Innocent", weapons[1]
end

local function getRoleColor(role)
    if role == "Killer"    then return espColors.killer    end
    if role == "Vigilante" then return espColors.vigilante end
    return espColors.innocent
end

-- ESP
local espEnabled = false
local espObjects = {}

local function cleanupESP(player)
    local obj = espObjects[player]
    if not obj then return end
    if obj.conn      then obj.conn:Disconnect()   end
    if obj.highlight then obj.highlight:Destroy() end
    if obj.billboard then obj.billboard:Destroy() end
    espObjects[player] = nil
end

local function setupESP(player)
    cleanupESP(player)
    if not espEnabled or player == lp then return end

    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local hl = Instance.new("Highlight")
    hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillTransparency    = 0.5
    hl.OutlineTransparency = 0
    hl.Adornee             = char
    hl.Parent              = CoreGui

    local bb = Instance.new("BillboardGui")
    bb.Size        = UDim2.fromOffset(200, 44)
    bb.StudsOffset = Vector3.new(0, 3, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = 1000
    bb.Adornee     = hrp
    bb.Parent      = CoreGui

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size                   = UDim2.fromScale(1, 1)
    lbl.TextScaled             = false
    lbl.TextSize               = 12
    lbl.RichText               = true
    lbl.Font                   = Enum.Font.GothamBold
    lbl.TextStrokeTransparency = 0.35
    lbl.TextColor3             = Color3.new(1, 1, 1)
    lbl.Parent                 = bb

    local conn = RunService.RenderStepped:Connect(function()
        if not char.Parent or hum.Health <= 0 then
            hl.Enabled = false
            bb.Enabled = false
            return
        end

        local role, weapon = getPlayerRole(player)
        local color        = getRoleColor(role)
        local dist         = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)
        local hp           = math.floor(hum.Health)

        hl.FillColor    = color
        hl.OutlineColor = color
        hl.Enabled      = true
        bb.Enabled      = true

        lbl.Text = string.format(
            "<font size=\"11\"><b>[%s] %s</b></font>\n<font size=\"10\">%d hp  %d dist  %s</font>",
            role,
            player.Name,
            hp,
            dist,
            weapon or "none"
        )
    end)

    espObjects[player] = { highlight = hl, billboard = bb, conn = conn }
end

local function enableAllESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and p.Character then setupESP(p) end
    end
end

local function disableAllESP()
    for p in pairs(espObjects) do cleanupESP(p) end
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= lp then
        p.CharacterAdded:Connect(function()
            task.wait(0.2)
            if espEnabled then setupESP(p) end
        end)
        p.AncestryChanged:Connect(function(_, parent)
            if not parent then cleanupESP(p) end
        end)
    end
end

