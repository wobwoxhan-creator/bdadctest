-- inject payload into gun actor - matches sneekygoober's injection method exactly
local injectedActors = {}

local function injectActor(char)
    task.wait()
    local gun = char:FindFirstChildOfClass("Tool")
    if not gun then return end
    local a = gun:FindFirstChild("Actor")
    if not a then return end

    if get_actors then
        local ok, actors = pcall(get_actors)
        if ok and actors then
            local found = false
            for _, v in next, actors do
                if v == a then found = true; break end
            end
            if not found then return end
        end
    end

    if injectedActors[a] then return end

    task.spawn(function()
        local retries = 0
        while retries < 100 do
            if not a.Parent or not a:IsDescendantOf(char) then return end
            local ok = pcall(run_on_actor, a, PAYLOAD)
            if ok then
                injectedActors[a] = true
                print("ADC Hub: injected into", a:GetFullName())
                break
            end
            retries += 1
            task.wait(0.05)
        end
        if not injectedActors[a] then
            warn("ADC Hub: failed to inject into", a:GetFullName())
        end
    end)
end

local charConn
local function setupChar(char)
    table.clear(injectedActors)
    if charConn then charConn:Disconnect(); charConn = nil end

    charConn = char.ChildAdded:Connect(function(child)
        if child.ClassName == "Tool" and child:FindFirstChild("Actor") and child.Actor:FindFirstChild("weap_cl") then
            injectActor(char)
        end
    end)

    local existing = char:FindFirstChildOfClass("Tool")
    if existing and existing:FindFirstChild("Actor") and existing.Actor:FindFirstChild("weap_cl") then
        injectActor(char)
    end
end

if lp.Character then setupChar(lp.Character) end
lp.CharacterAdded:Connect(function(char)
    task.wait(0.1)
    setupChar(char)
end)

