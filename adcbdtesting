task.spawn(function()
    local cloneref = cloneref or function(i) return i end
    local clonefunction = clonefunction or function(f) return f end
    local newcclosure = newcclosure or clonefunction
    local UIS = cloneref(game:GetService("UserInputService"))
    local isMobile = UIS.TouchEnabled and not UIS.KeyboardEnabled and not UIS.MouseEnabled

    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.IgnoreWater = true

    local function setupRayParams(char)
        if not char then return end
        local filters = {char}
        if BloodFolder then
            for _, name in ipairs({"ALWAYSHERE", "CheckingWalking", "INVISBARRIERS", "Spawns", "TREES", "InvisibleWall", "Cleaning windows"}) do
                local v = BloodFolder:FindFirstChild(name, true)
                if v then table.insert(filters, v) end
            end
            for _, v in ipairs(BloodFolder:GetDescendants()) do
                if v.Name:lower():match("window", 1) then table.insert(filters, v) end
            end
        end
        rp.FilterDescendantsInstances = filters
    end

    setupRayParams(lp.Character)
    lp.CharacterAdded:Connect(setupRayParams)

    local function isVisible(part, origin)
        if not part then return false end
        local result = workspace:Raycast(origin, part.Position - origin, rp)
        if not result then return true end
        if result.Instance:IsDescendantOf(part.Parent) then return true end
        return false
    end

    local function getTarget(origin)
        if not getgenv().saEnabled then return nil end
        local targets = getgenv().validSATargets or {}
        local cam = workspace.CurrentCamera
        local bestPart = nil
        local bestDist = getgenv().saFovRadius or 300
        if not NPCSFolder then return nil end
        for _, npcChar in ipairs(NPCSFolder:GetChildren()) do
            if npcChar == lp.Character then continue end
            if not targets[npcChar.Name] then continue end
            local hum = npcChar:FindFirstChild("Humanoid")
            if hum and hum.Health <= 0 then continue end
            if npcChar:FindFirstChildOfClass("ForceField") then continue end
            local tPart = npcChar:FindFirstChild("Head") or npcChar.PrimaryPart or npcChar:FindFirstChild("HumanoidRootPart")
            if not tPart then continue end
            local pos, onScreen = cam:WorldToViewportPoint(tPart.Position)
            if not onScreen then continue end
            if getgenv().wallcheck then
                if not isVisible(tPart, origin) then continue end
            end
            local mousePos = isMobile and Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2) or UIS:GetMouseLocation()
            local screenDist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
            if screenDist < bestDist then
                bestPart = tPart
                bestDist = screenDist
            end
        end
        return bestPart
    end

    local hooked = false

    local function hookGun()
        if hooked then return end
        local s, rep = pcall(require, ReplicatedStorage.gun_res.lib.replicator)
        if not s or not rep then return warn("couldnt require replicator:", tostring(rep)) end
        local bulletFn = rawget(rep, "bullet")
        if not bulletFn then return warn("couldnt find bullet fn") end
        local old
        old = clonefunction(hookfunction(bulletFn, newcclosure(function(_, __, ___, ____, origin, endPoses, ...)
            local target = getTarget(origin)
            if target then
                return old(_, __, ___, ____, origin, table.create(#endPoses, (target.Position - origin).Unit), ...)
            end
            return old(_, __, ___, ____, origin, endPoses, ...)
        end)))
        hooked = true
        if restorefunction and isfunctionhooked then
            lp.CharacterRemoving:Connect(function()
                if rep and rawget(rep, "bullet") and isfunctionhooked(rawget(rep, "bullet")) then
                    restorefunction(rawget(rep, "bullet"))
                    hooked = false
                end
            end)
        end
    end

    local function watchChar(char)
        if not char then return end
        task.wait(0.2)
        local gun = char:FindFirstChildOfClass("Tool")
        if gun and gun:FindFirstChild("Actor") and gun.Actor:FindFirstChild("weap_cl") then
            hookGun()
        else
            local conn
            conn = char.ChildAdded:Connect(function(child)
                if child.ClassName == "Tool" and child:FindFirstChild("Actor") and child.Actor:FindFirstChild("weap_cl") then
                    conn:Disconnect()
                    hookGun()
                end
            end)
        end
    end

    watchChar(lp.Character)
    lp.CharacterAdded:Connect(function(char)
        hooked = false
        watchChar(char)
    end)
end)
